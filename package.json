{
  "name": "home-inventory",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:ensure-admin": "tsx prisma/seed.ts",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/create-release.ps1",
    "postinstall": "prisma generate",
    "cap:sync": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "apk:build": "npx cap sync android && npx cap open android",
    "apk:icons": "npx capacitor-assets generate --iconBackgroundColor \"#2563eb\" --splashBackgroundColor \"#2563eb\" --android"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^6.2.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.2.0",
    "@eslint/eslintrc": "^3.3.1",
    "@netlify/plugin-nextjs": "^5.11.2",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
